generator client {
  provider      = "prisma-client-js"
  output        = "../generated-client"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String         @id @default(cuid())
  clerkId                   String?        @unique
  email                     String         @unique
  name                      String?
  points                    Int            @default(0)
  savedAddresses            Json?          @default("[]")
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt
  password                  String?
  phone                     String?        @unique
  referralCode              String?        @unique
  resetExpires              DateTime?
  resetToken                String?        @unique
  roleId                    String?
  role                      UserRole       @default(CUSTOMER)
  interests                 String[]       @default([])
  lastActiveAt              DateTime?
  Order_Order_staffIdToUser Order[]        @relation("Order_staffIdToUser")
  orders                    Order[]
  referralRecvd             Referral?      @relation("Referee")
  referralsSent             Referral[]     @relation("Referrer")
  reviews                   Review[]
  roleRef                   Role?          @relation(fields: [roleId], references: [id])
  wallet                    Wallet?
  WishlistItem              WishlistItem[]
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  color       String?      @default("bg-gray-100 text-gray-600")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  users       User[]
  permissions Permission[] @relation("PermissionToRole")
}

model Permission {
  id          String   @id @default(cuid())
  action      String   @unique
  description String?
  createdAt   DateTime @default(now())
  roles       Role[]   @relation("PermissionToRole")
}

model Product {
  id                  String               @id @default(cuid())
  handle              String               @unique
  title               String
  description         String?
  vendor              String?
  tags                String               @default("")
  published           Boolean              @default(false)
  hsnCode             String               @default("TEXTILE-00")
  lowStockThreshold   Int                  @default(10)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  shopifyId           String?              @unique
  ageGroup            String?
  brand               String?
  category            String?
  fabric              String?
  fitType             String?
  gender              String?
  length              String?
  material            String?
  metaDescription     String?
  metaKeywords        String?
  neckType            String?
  occasion            String?
  pattern             String?
  productType         String?
  searchKeywords      String?
  seoTitle            String?
  sleeveType          String?
  status              String               @default("DRAFT")
  style               String?
  subCategory         String?
  collection          String?
  sizeGuideId         String?
  taxInclusive        Boolean              @default(true)
  taxRate             Decimal              @default(5.00)
  images              Image[]
  sizeGuide           SizeGuide?           @relation(fields: [sizeGuideId], references: [id])
  reviews             Review[]
  variants            Variant[]
  wholesaleOrderItems WholesaleOrderItem[]
  WishlistItem        WishlistItem[]
  collections         Collection[]         @relation("CollectionProducts")
}

model Variant {
  id                  String               @id @default(cuid())
  productId           String
  sku                 String?              @unique
  price               Decimal
  inventory           Int                  @default(0)
  option1Name         String?
  option1Value        String?
  option2Name         String?
  option2Value        String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  option3Name         String?
  option3Value        String?
  barcode             String?              @unique
  costPrice           Decimal?
  discountPercentage  Decimal?
  mrp                 Decimal?
  offerPrice          Decimal?
  sellingPrice        Decimal?
  currency            String               @default("INR")
  images              Image[]              @relation("VariantImages")
  orderItems          OrderItem[]
  purchaseOrderItems  PurchaseOrderItem[]
  stockLogs           StockLog[]
  reservations        StockReservation[]
  product             Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  wholesaleOrderItems WholesaleOrderItem[]
}

model Image {
  id        String   @id @default(cuid())
  url       String
  altText   String?
  position  Int      @default(0)
  productId String?
  variantId String?
  reviewId  String?
  createdAt DateTime @default(now())
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  review    Review?  @relation("ReviewImages", fields: [reviewId], references: [id])
  variant   Variant? @relation("VariantImages", fields: [variantId], references: [id])
}

model Collection {
  id          String    @id @default(cuid())
  handle      String    @unique
  title       String
  description String?
  image       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  shopifyId   String?   @unique
  products    Product[] @relation("CollectionProducts")
}

model Order {
  id                       String          @id @default(cuid())
  userId                   String?
  status                   OrderStatus     @default(PAYMENT_PENDING)
  totalAmount              Decimal
  customerName             String
  customerEmail            String
  customerPhone            String
  shippingAddress          Json
  paymentMethod            String?
  paymentId                String?         @unique
  paymentIntentId          String?         @unique
  discountCode             String?
  discountAmount           Decimal?
  trackingId               String?
  carrierName              String?
  estimatedDelivery        DateTime?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  cancelledAt              DateTime?
  currency                 String?         @default("INR")
  financialStatus          String?         @default("pending")
  fulfilledAt              DateTime?
  fulfillmentStatus        String?         @default("unfulfilled")
  idempotencyKey           String?         @unique
  notes                    String?
  paidAt                   DateTime?
  paymentReference         String?
  riskLevel                String          @default("low")
  shipping                 Decimal?        @default(0)
  shippingMethod           String?
  source                   String          @default("web")
  subtotal                 Decimal?
  taxes                    Decimal?        @default(0)
  total                    Decimal?
  walletCreditUsed         Decimal?        @default(0)
  billingAddress           Json?
  internalNotes            String?
  riskScore                Int?            @default(0)
  sourceIp                 String?
  staffId                  String?
  userAgent                String?
  tags                     String[]        @default([])
  formattedOrderNumber     String?         @unique
  orderNumber              Int             @unique @default(autoincrement())
  fulfillments             Fulfillment[]
  User_Order_staffIdToUser User?           @relation("Order_staffIdToUser", fields: [staffId], references: [id])
  user                     User?           @relation(fields: [userId], references: [id])
  OrderActivity            OrderActivity[]
  items                    OrderItem[]
  returns                  OrderReturn[]
}

model OrderItem {
  id             String           @id @default(cuid())
  orderId        String
  variantId      String
  quantity       Int
  price          Decimal
  hsnCode        String?
  taxAmount      Decimal          @default(0)
  status         OrderItemStatus  @default(FULFILLED)
  order          Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant        Variant          @relation(fields: [variantId], references: [id])
  ReturnExchange ReturnExchange[]
}

model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String?
  rating    Int
  headline  String?
  content   String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
  images    Image[]  @relation("ReviewImages")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])
}

model Page {
  id              String     @id @default(cuid())
  handle          String     @unique
  title           String
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  metaDescription String?
  metaTitle       String?
  ogImage         String?
  publishedAt     DateTime?
  status          PageStatus @default(DRAFT)
  type            PageType   @default(LANDING)
  sections        Section[]
}

model Section {
  id        String      @id @default(cuid())
  pageId    String
  type      SectionType
  order     Int         @default(0)
  content   Json
  style     Json?
  settings  Json?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  page      Page        @relation(fields: [pageId], references: [id], onDelete: Cascade)
}

model ThemeSettings {
  id               String   @id @default("global")
  storeName        String   @default("Raaghas")
  updatedAt        DateTime @updatedAt
  config           Json?
  buttonRadius     String   @default("0.5rem")
  defaultThemeMode String   @default("LIGHT")
  faviconDark      String?
  faviconLight     String?
  fontBody         String   @default("sans")
  fontHeading      String   @default("serif")
  logoDark         String?
  logoLight        String?
  primaryColor     String   @default("#701A31")
  secondaryColor   String   @default("#F4F1ED")
  customFooterHtml String?
  customGlobalCss  String?
  footerConfig     Json?
}

model ThemePreset {
  id           String   @id @default(cuid())
  name         String
  description  String?
  previewImage String?
  config       Json
  isActive     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Media {
  id        String   @id @default(cuid())
  filename  String
  url       String
  type      String   @default("image")
  size      Int?
  mimeType  String?
  createdAt DateTime @default(now())
  folder    String   @default("All")
  updatedAt DateTime @updatedAt
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Retailer {
  id             String           @id @default(cuid())
  clerkId        String?          @unique
  businessName   String
  contactName    String
  email          String           @unique
  phone          String
  gstNumber      String?
  address        String?
  city           String?
  state          String?
  tier           RetailerTier     @default(SILVER)
  status         RetailerStatus   @default(PENDING)
  creditLimit    Decimal?
  creditTermDays Int?             @default(0)
  notes          String?
  priceListId    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  priceList      PriceList?       @relation(fields: [priceListId], references: [id])
  orders         WholesaleOrder[]
}

model PriceList {
  id              String     @id @default(cuid())
  name            String     @unique
  discountPercent Decimal
  moqPerSku       Int        @default(1)
  moqPerOrder     Decimal?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  retailers       Retailer[]
}

model WholesaleOrder {
  id          String               @id @default(cuid())
  retailerId  String
  status      String               @default("DRAFT")
  totalAmount Decimal              @default(0)
  advancePaid Decimal              @default(0)
  notes       String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  isPublished Boolean              @default(false)
  emailSentAt DateTime?
  retailer    Retailer             @relation(fields: [retailerId], references: [id])
  items       WholesaleOrderItem[]
}

model WholesaleOrderItem {
  id                 String         @id @default(cuid())
  orderId            String
  productId          String
  variantId          String
  quantity           Int
  unitMrp            Decimal
  unitWholesalePrice Decimal
  totalPrice         Decimal
  hsnCode            String?
  order              WholesaleOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product            Product        @relation(fields: [productId], references: [id])
  variant            Variant        @relation(fields: [variantId], references: [id])
}

model Discount {
  id                   String          @id @default(cuid())
  code                 String          @unique
  type                 DiscountType
  value                Decimal
  minOrderValue        Decimal?
  usedCount            Int             @default(0)
  isActive             Boolean         @default(true)
  expiresAt            DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  applicableCategories String[]        @default([])
  applicableProducts   String[]        @default([])
  endDate              DateTime?
  isStackable          Boolean         @default(false)
  maxDiscount          Decimal?
  startDate            DateTime?
  usageLimit           Int?
  usageLimitPerUser    Int             @default(1)
  autoApply            Boolean         @default(false)
  minQuantity          Int?            @default(1)
  usages               DiscountUsage[]
}

model DiscountUsage {
  id         String   @id @default(cuid())
  discountId String
  userId     String
  orderId    String
  createdAt  DateTime @default(now())
  discount   Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
}

model StoreSettings {
  id                        String   @id @default("global")
  storeName                 String   @default("Raaghas")
  logoUrl                   String?
  supportEmail              String?
  supportPhone              String?
  tagline                   String?  @default("Luxury ethnic wear crafted for the moments that matter most.")
  footerCopyright           String?  @default("All rights reserved.")
  instagramUrl              String?
  facebookUrl               String?
  twitterUrl                String?
  pinterestUrl              String?
  youtubeUrl                String?
  whatsappApiUrl            String?  @default("https://api.grafty.pro/v1")
  whatsappApiKey            String?
  whatsappAppId             String?
  bankName                  String?  @default("HDFC Bank")
  bankBranch                String?
  accountNumber             String?
  accountName               String?
  ifscCode                  String?
  gstNumber                 String?
  businessAddress           String?
  businessState             String?  @default("Tamil Nadu")
  defaultGstRate            Decimal? @default(5.00)
  updatedAt                 DateTime @updatedAt
  activePaymentGateway      String?  @default("RAZORPAY")
  phonepeMerchantId         String?
  phonepeMerchantUserId     String?
  phonepeSaltIndex          String?  @default("1")
  phonepeSaltKey            String?
  razorpayKeyId             String?
  razorpayKeySecret         String?
  googleAuthSecret          String?
  googleClientId            String?
  googleClientSecret        String?
  graftyApiKey              String?
  graftyApiUrl              String?  @default("https://grafty.pro/api/integrations/v1/event")
  graftyWorkspaceId         String?
  metaCapiToken             String?
  metaPixelId               String?
  smtpHost                  String?
  smtpPass                  String?
  smtpPort                  Int?     @default(587)
  smtpSecure                Boolean  @default(false)
  smtpUser                  String?
  customFooterHtml          String?
  customGlobalCss           String?
  customHeadHtml            String?
  googleAnalyticsId         String?
  googleSearchConsoleKey    String?
  whatsappBusinessAccountId String?
  whatsappPhoneNumberId     String?
  maxCreditUsagePercent     Decimal? @default(50.00)
  referralRewardPercent     Decimal? @default(10.00)
  welcomeDiscountPercent    Decimal? @default(10.00)
  loyaltyMinOrderValue      Decimal? @default(2000.00)
  loyaltyPointsRate         Decimal? @default(1.00)
  delhiveryPickupLocation   String?
  delhiveryToken            String?
  razorpayWebhookSecret     String?
  shiprocketEmail           String?
  shiprocketPassword        String?
  shiprocketPickupLocation  String?
  autoApproveLowValue       Boolean  @default(false)
  requireImagesForReturn    Boolean  @default(true)
  returnWindowDays          Int      @default(7)
  orderPrefix               String?
  orderSuffix               String?
}

model LedgerEntry {
  id           String     @id @default(cuid())
  type         LedgerType
  amount       Decimal
  referenceId  String?
  partyName    String?
  status       String     @default("COMPLETED")
  notes        String?
  isDraft      Boolean    @default(false)
  taxableValue Decimal?
  cgst         Decimal?
  sgst         Decimal?
  igst         Decimal?
  totalTax     Decimal?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model PaymentIntent {
  id               String   @id @default(cuid())
  providerOrderId  String   @unique
  gateway          String
  amount           Decimal
  status           String   @default("PENDING")
  customerInfo     Json
  metadata         Json?
  orderId          String?  @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  clerkId          String?
  walletCreditUsed Decimal? @default(0)
}

model StockLog {
  id          String       @id @default(cuid())
  variantId   String
  type        StockLogType
  change      Int
  newBalance  Int
  referenceId String?
  notes       String?
  createdAt   DateTime     @default(now())
  variant     Variant      @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

model StockReservation {
  id            String   @id @default(cuid())
  variantId     String
  orderId       String?
  proformaId    String?
  quantity      Int
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orderIntentId String?
  variant       Variant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

model WebhookEvent {
  id          String        @id @default(cuid())
  gateway     String
  eventType   String
  status      WebhookStatus @default(RECEIVED)
  rawPayload  Json
  signature   String?
  attempts    Int           @default(0)
  maxAttempts Int           @default(5)
  nextRetryAt DateTime?
  lastError   String?
  deadReason  String?
  deadAt      DateTime?
  orderId     String?
  createdAt   DateTime      @default(now())
  processedAt DateTime?

  @@index([status, nextRetryAt])
  @@index([gateway, eventType])
}

model SupportInquiry {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  type      InquiryType   @default(GENERAL)
  status    InquiryStatus @default(PENDING)
  orderId   String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Menu {
  id        String     @id @default(cuid())
  name      String
  handle    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     MenuItem[]
}

model MenuItem {
  id        String     @id @default(cuid())
  label     String
  url       String
  order     Int        @default(0)
  menuId    String
  parentId  String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  menu      Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  parent    MenuItem?  @relation("MenuSubItems", fields: [parentId], references: [id])
  children  MenuItem[] @relation("MenuSubItems")
}

model CheckoutLead {
  id        String     @id @default(cuid())
  email     String?
  phone     String
  name      String?
  cartTotal Decimal
  items     Json?
  status    LeadStatus @default(PENDING)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([phone, email])
}

model Campaign {
  id          String    @id @default(cuid())
  name        String
  content     String
  status      String    @default("DRAFT")
  metrics     Json?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AIStyleRule {
  id             String   @id @default(cuid())
  trigger        String   @unique
  recommendation String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  name           String
}

model Supplier {
  id             String          @id @default(cuid())
  name           String
  contactPerson  String?
  email          String?
  phone          String?
  gstNumber      String?
  address        String?
  category       String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  purchaseOrders PurchaseOrder[]
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  supplierId  String
  status      PurchaseStatus      @default(PENDING)
  totalCost   Decimal
  autoRestock Boolean             @default(false)
  notes       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  supplier    Supplier            @relation(fields: [supplierId], references: [id])
  items       PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  variantId       String
  quantity        Int
  costPrice       Decimal
  gstRate         Decimal       @default(5.00)
  hsnCode         String?
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  variant         Variant       @relation(fields: [variantId], references: [id])
}

model Invoice {
  id            String           @id @default(cuid())
  invoiceNumber String           @unique
  referenceId   String?
  referenceType String?
  customerName  String
  customerEmail String
  customerPhone String?
  date          DateTime         @default(now())
  dueDate       DateTime?
  status        String           @default("DRAFT")
  subtotal      Decimal
  taxAmount     Decimal
  totalAmount   Decimal
  amountPaid    Decimal          @default(0)
  tableData     Json
  customFields  Json?
  templateId    String?
  signatureUrl  String?
  watermarkUrl  String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  template      InvoiceTemplate? @relation(fields: [templateId], references: [id])
}

model InvoiceTemplate {
  id           String    @id @default(cuid())
  name         String
  layout       String
  headerHtml   String?
  footerHtml   String?
  primaryColor String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  invoices     Invoice[]
}

model Wallet {
  id           String              @id @default(cuid())
  userId       String              @unique
  balance      Decimal             @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  user         User                @relation(fields: [userId], references: [id])
  transactions WalletTransaction[]
}

model WalletTransaction {
  id          String         @id @default(cuid())
  walletId    String
  amount      Decimal
  type        WalletTxType
  reason      WalletTxReason
  status      String         @default("COMPLETED")
  referenceId String?
  notes       String?
  createdAt   DateTime       @default(now())
  wallet      Wallet         @relation(fields: [walletId], references: [id])
}

model Referral {
  id           String         @id @default(cuid())
  referrerId   String
  refereeId    String         @unique
  status       ReferralStatus @default(PENDING)
  rewardAmount Decimal?
  orderId      String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  referee      User           @relation("Referee", fields: [refereeId], references: [id])
  referrer     User           @relation("Referrer", fields: [referrerId], references: [id])
}

model OfferRule {
  id          String   @id @default(cuid())
  name        String
  description String?
  priority    Int      @default(0)
  isActive    Boolean  @default(true)
  conditions  Json
  actions     Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ShippingZone {
  id        String           @id @default(cuid())
  name      String           @unique
  regions   String[]
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  methods   ShippingMethod[]
}

model ShippingMethod {
  id            String       @id @default(cuid())
  zoneId        String
  name          String
  description   String?
  baseCost      Decimal      @default(0)
  minOrderValue Decimal?
  maxWeight     Decimal?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  zone          ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
}

model Courier {
  id          String     @id @default(cuid())
  name        String     @unique
  website     String?
  trackingUrl String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  shipments   Shipment[]
}

model Fulfillment {
  id        String            @id @default(cuid())
  orderId   String
  status    String            @default("PENDING")
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  order     Order             @relation(fields: [orderId], references: [id])
  items     FulfillmentItem[]
  shipments Shipment[]
}

model FulfillmentItem {
  id            String      @id @default(cuid())
  fulfillmentId String
  variantId     String
  quantity      Int
  fulfillment   Fulfillment @relation(fields: [fulfillmentId], references: [id], onDelete: Cascade)
}

model Shipment {
  id                String         @id @default(cuid())
  fulfillmentId     String
  courierId         String?
  trackingId        String?        @unique
  status            ShipmentStatus @default(PENDING)
  estimatedDelivery DateTime?
  shippedAt         DateTime?
  deliveredAt       DateTime?
  trackingHistory   Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  courier           Courier?       @relation(fields: [courierId], references: [id])
  fulfillment       Fulfillment    @relation(fields: [fulfillmentId], references: [id], onDelete: Cascade)
}

model OrderReturn {
  id           String       @id @default(cuid())
  orderId      String
  status       ReturnStatus @default(REQUESTED)
  reason       String
  notes        String?
  refundAmount Decimal?
  refundStatus String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  order        Order        @relation(fields: [orderId], references: [id])
  items        ReturnItem[]
}

model ReturnItem {
  id        String      @id @default(cuid())
  returnId  String
  variantId String
  quantity  Int
  return    OrderReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
}

model Otp {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model EmailTemplate {
  id        String   @id @default(cuid())
  name      String   @unique
  type      String   @unique
  subject   String
  body      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NotificationLog {
  id          String   @id @default(cuid())
  type        String
  channel     String
  recipient   String
  status      String   @default("SENT")
  error       String?
  referenceId String?
  createdAt   DateTime @default(now())
}

model SizeGuide {
  id          String    @id @default(cuid())
  name        String    @unique
  htmlContent String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model OrderActivity {
  id        String   @id
  orderId   String
  type      String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())
  Order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model ReturnExchange {
  id           String             @id
  orderItemId  String
  orderId      String
  type         ReturnExchangeType
  newVariantId String?
  restocked    Boolean            @default(false)
  refundAmount Decimal?
  refundMethod String?
  notes        String?
  createdAt    DateTime           @default(now())
  OrderItem    OrderItem          @relation(fields: [orderItemId], references: [id])
}

